# ── Required ──────────────────────────────────────────────────────────────

# OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# JWT secret — use a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────

# For local development without Docker, SQLite is used automatically.
# Uncomment and fill in for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/aipdfchat

# Used by docker-compose to create the PostgreSQL container:
POSTGRES_USER=aipdfuser
POSTGRES_PASSWORD=changeme

# ── Optional tuning ───────────────────────────────────────────────────────

# JWT token expiry in minutes (default 1440 = 24 hours)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
